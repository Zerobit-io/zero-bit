# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Firebase ──────────────────────────────────────────────────
# Used for JWT claim validation in sync-user.handler.js
FIREBASE_PROJECT_ID=your_firebase_project_id

# ── Hasura / PostgreSQL ────────────────────────────────────────
# Server-side only — never expose this as NEXT_PUBLIC_
HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql
HASURA_ADMIN_SECRET=myadminsecretkey

# ── TrustlessWork ──────────────────────────────────────────────
TRUSTLESS_WORK_BASE_URL=https://dev.api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_api_key_here

# ── Stellar ────────────────────────────────────────────────────
PLATFORM_STELLAR_ADDRESS=your_stellar_address_here
